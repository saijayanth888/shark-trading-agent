# Shark Trading Agent — Environment Variables
# Copy this to .env for local use. NEVER commit .env to git.
# In cloud routines, set these as environment variables on the routine itself.

# ── Alpaca (paper trading to start) ──────────────────────────────────────
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here
ALPACA_BASE_URL=https://paper-api.alpaca.markets
# Switch to https://api.alpaca.markets for live trading

# ── Perplexity (market research) ─────────────────────────────────────────
PERPLEXITY_API_KEY=your_perplexity_api_key_here
PERPLEXITY_MODEL=sonar-pro

# ── Anthropic (agent brain) ───────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── SendGrid (email notifications) ───────────────────────────────────────
SENDGRID_API_KEY=your_sendgrid_api_key_here
NOTIFY_EMAIL=your_email@gmail.com
NOTIFY_FROM_EMAIL=shark@trading.bot

# ── Trading Mode ──────────────────────────────────────────────────────────
TRADING_MODE=paper
# Options: paper | live

# ── Risk Parameters (overrides CLAUDE.md defaults) ───────────────────────
MAX_POSITIONS=6
MAX_POSITION_PCT=0.20
MAX_WEEKLY_TRADES=3
MIN_CASH_BUFFER_PCT=0.15
CIRCUIT_BREAKER_PCT=0.15
MAX_SECTOR_FAILURES=2
